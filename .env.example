# blade.io — environment variables
# Copy this file to .env and fill in the values from your Supabase project.
# (.env is git-ignored.)

# ---------------------------------------------------------------------------
# Server (Node / Colyseus) — never commit, never expose to the client.
# ---------------------------------------------------------------------------
# Project URL, e.g. https://abcdefghijkl.supabase.co
SUPABASE_URL=
# anon (public) key — used to verify JWTs sent by clients
SUPABASE_ANON_KEY=
# service role key — bypasses RLS, only the game server should hold it
SUPABASE_SERVICE_ROLE_KEY=

# Optional override of the listen port (default 2567)
# PORT=2567

# ---------------------------------------------------------------------------
# Client (Vite) — variables prefixed with VITE_ are bundled into the client
# bundle. Only put public values here. The service role key MUST NOT be
# exposed to the client.
# ---------------------------------------------------------------------------
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional: explicit WebSocket URL of the Colyseus server. If unset, the
# client derives it from window.location (wss://hostname).
# VITE_SERVER_URL=wss://example.com
